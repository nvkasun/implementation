{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadGoldenGateDevSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:eu-west-1:668311715351:secret:dev/goldengate/*"
      ]
    },
    {
      "Sid": "AllowDecryptGoldenGateSecretsKms",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowWriteGoldenGateMonitoringState",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DescribeTable"
      ],
      "Resource": "arn:aws:dynamodb:eu-west-1:668311715351:table/gg-eks-pipeline"
    },
    {
      "Sid": "AllowPublishGoldenGateMonitoringMetrics",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:PutMetricData"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "cloudwatch:namespace": "GoldenGate/Pipelines"
        }
      }
    }
  ]
}